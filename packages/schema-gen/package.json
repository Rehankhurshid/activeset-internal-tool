{
  "name": "@activeset/schema-gen",
  "version": "0.2.0",
  "description": "Generate Schema.org JSON-LD recommendations for Webflow static pages using a local Ollama model (Gemma by default). Output is a portable JSON file you can import into the ActiveSet dashboard.",
  "keywords": [
    "schema-org",
    "json-ld",
    "structured-data",
    "seo",
    "webflow",
    "ollama",
    "gemma"
  ],
  "license": "MIT",
  "author": "ActiveSet",
  "type": "commonjs",
  "bin": {
    "schema-gen": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
