rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────────────────────────
    // project_secrets — server-only. Stores third-party API tokens
    // (Webflow, etc.). Writes and reads must go through firebase-admin
    // on the server; deny everything to client SDKs.
    // ──────────────────────────────────────────────────────────────────────
    match /project_secrets/{projectId} {
      allow read, write: if false;
    }

    // ──────────────────────────────────────────────────────────────────────
    // projects — owner-only (or admin). The public embed widget reads
    // project data through /api/project/[id] on the server (which
    // whitelists public fields), so direct client reads are only for the
    // signed-in dashboard.
    // ──────────────────────────────────────────────────────────────────────
    match /projects/{projectId} {
      function isActiveSetUser() {
        return request.auth != null
          && request.auth.token.email is string
          && request.auth.token.email.lower().matches('.*@activeset[.]co');
      }
      function isOwner() {
        return request.auth != null
          && resource.data.userId == request.auth.uid;
      }
      function isAdmin() {
        return request.auth != null
          && request.auth.token.email == 'rehan@activeset.co';
      }
      // SECURITY: never allow client writes of webflowConfig.apiToken —
      // the token must live in project_secrets/{projectId} instead.
      // We accept incoming writes only if that field is absent.
      function writeHasNoApiToken() {
        return !('webflowConfig' in request.resource.data)
          || request.resource.data.webflowConfig == null
          || !('apiToken' in request.resource.data.webflowConfig);
      }

      allow read: if isOwner() || isAdmin();
      allow create: if isActiveSetUser()
        && request.resource.data.userId == request.auth.uid
        && writeHasNoApiToken();
      allow update: if (isOwner() || isAdmin()) && writeHasNoApiToken();
      allow delete: if isOwner() || isAdmin();

      // Audit subcollections inherit the same ownership model.
      match /link_audits/{linkId} {
        allow read, write: if isOwner() || isAdmin();
      }
    }

    // Proposal Comments - allow authenticated agency users and public access for shared proposals
    match /proposal_comments/{commentId} {
      // Allow authenticated users to read/write comments
      allow read, write: if request.auth != null;

      // Allow unauthenticated users to add comments on shared proposals (for clients)
      allow create: if request.resource.data.authorType == 'client';
      allow read: if true;
    }

    // Proposal History - read-only for authenticated users, write via service
    match /proposal_history/{historyId} {
      // Allow authenticated users to read history
      allow read: if request.auth != null;

      // Allow writes from authenticated users (for edit tracking)
      allow write: if request.auth != null;

      // Allow unauthenticated writes for signature events (clients signing)
      allow create: if request.resource.data.changeType == 'signed';
    }

    // Webflow Sessions - allow public access for extension communication
    match /webflow_sessions/{sessionId} {
      // Allow anyone to read/write sessions (extension runs without auth)
      allow read, write: if true;
    }
  }
}
