{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["/usr/local/bin/npx", "next", "dev", "--turbopack"],
      "port": 3000,
      "autoPort": true,
      "env": {
        "PATH": "/usr/local/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/bin:/bin"
      }
    }
  ]
}
